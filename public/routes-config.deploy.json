{
  "_COPILOT_PROHIBITION_WARNING": "🚨 COPILOT AGENTS ARE STRICTLY PROHIBITED FROM MAKING ANY CHANGES TO THIS FILE WITHOUT EXPLICIT WRITTEN CONSENT FROM @litlfred - This file controls deploy branch route configuration and component loading. Unauthorized changes can break the deployment system. 🚨",
  "deployType": "deploy",
  "components": {
    "BranchListingPage": {
      "path": "./components/BranchListingPage",
      "routes": [
        { "path": "/", "exact": true }
      ]
    },
    "FunctionalRequirementsEditor": {
      "path": "./components/FunctionalRequirementsEditor",
      "routes": [
        { "path": "/functional-requirements", "exact": true },
        { "path": "/functional-requirements/:user", "exact": true },
        { "path": "/functional-requirements/:user/:repo", "exact": true },
        { "path": "/functional-requirements/:user/:repo/:branch", "exact": true },
        { "path": "/functional-requirements/:user/:repo/:branch/*", "exact": false }
      ]
    },
    "NotFound": {
      "path": "./components/NotFound",
      "routes": [
        { "path": "*", "fallback": true }
      ]
    }
  }
}